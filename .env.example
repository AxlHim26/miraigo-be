# Application
APP_PORT=8080
TZ=UTC

# Database
POSTGRES_DB=elearning_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_this_strong_password

# Redis
# Keep empty to disable password
REDIS_PASSWORD=

# Security (required)
# Base64 secret is recommended for JWT_SECRET_KEY
JWT_SECRET_KEY=replace_with_strong_jwt_secret
JWT_ACCESS_TOKEN_EXPIRATION=24h
JWT_REFRESH_TOKEN_EXPIRATION=7d
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://admin.example.com,https://app.example.com

# Database schema strategy (validate | update). Use update only for bootstrap.
JPA_DDL_AUTO=validate
AUTH_REFRESH_COOKIE_NAME=nm_refresh_token
AUTH_COOKIE_PATH=/api/v1/auth
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=None
EMAIL_VERIFICATION_WEB_BASE_URL=http://localhost:3000
EMAIL_VERIFICATION_PATH=/verify-email
EMAIL_VERIFICATION_FROM_ADDRESS=your_email@gmail.com
EMAIL_VERIFICATION_TOKEN_EXPIRATION=30m

# SMTP mail delivery
# Example below uses Gmail SMTP. For Gmail, use a 16-character App Password.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_admin_password
